# Used for: `make init`, `make terraform-apply`, `make deploy`
# against the SHARED server hosting development + preproduction.

# Hetzner Cloud Configuration
TF_VAR_hcloud_token=""

# Selects both the OpenTofu workspace/state AND which terraform/environments/*.tfvars
# file is used (must match a filename in that folder, without the extension).
TF_WORKSPACE="development-preproduction"

# Which environment(s) this server hosts. Must match TF_WORKSPACE's bucket list.
TARGET_ENVIRONMENTS="development,preproduction"

# SSH Configuration (used by `make deploy` / `make wait-for-ssh`)
SSH_KEY_PATH="~/.ssh/id_ed25519"

# Hetzner Object Storage (Cloud Console -> Object Storage -> Manage keys)
# Account-wide credentials, used to create/manage buckets via Terraform.
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# One password per environment hosted on this server.
POSTGRES_DB_PASSWORD_DEVELOPMENT=""
POSTGRES_DB_PASSWORD_PREPRODUCTION=""
