# Used for: `make duckdb` -- connects to the PRODUCTION CALIBRATION dataset.
# Lives on the dedicated production server (different SSH_HOST from dev/preprod).
# Shares the same Postgres ROLE as .env.production, just a different
# DATABASE and S3 bucket.

# Windows: use a full path like C:\Users\you\.ssh\id_ed25519 -- ~ does not expand reliably here
SSH_KEY_PATH="~/.ssh/id_ed25519"
# IP of the dedicated production server (same as .env.production)
SSH_HOST=""

POSTGRES_DATABASE="ducklake_catalog_production_calibration"
POSTGRES_USER="ducklake_production"
# must match POSTGRES_DB_PASSWORD_PRODUCTION used at deploy time (shared with measurements)
POSTGRES_DB_PASSWORD=""

S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT="nbg1.your-objectstorage.com"
S3_REGION="nbg1"
S3_BUCKET_NAME="data-palantir-production-calibration"
S3_DATA_PATH="s3://data-palantir-production-calibration/"
S3_USE_SSL=true
