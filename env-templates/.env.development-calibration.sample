# Used for: `make duckdb` -- connects to the DEVELOPMENT CALIBRATION dataset.
# Lives on the shared development-preproduction server.
# Shares the same Postgres ROLE as .env.development (by design), just a
# different DATABASE and S3 bucket.

# Windows: use a full path like C:\Users\you\.ssh\id_ed25519 -- ~ does not expand reliably here
SSH_KEY_PATH="~/.ssh/id_ed25519"
# IP of the shared development-preproduction server (same as .env.development)
SSH_HOST=""

POSTGRES_DATABASE="ducklake_catalog_calibration"
POSTGRES_USER="ducklake"
# must match POSTGRES_DB_PASSWORD_DEVELOPMENT used at deploy time (shared with measurements)
POSTGRES_DB_PASSWORD=""

S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT="nbg1.your-objectstorage.com"
S3_REGION="nbg1"
S3_BUCKET_NAME="data-palantir-development-calibration"
S3_DATA_PATH="s3://data-palantir-development-calibration/"
S3_USE_SSL=true
