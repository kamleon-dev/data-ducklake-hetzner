# Used for: `make init`, `make terraform-apply`, `make deploy`
# against the DEDICATED production server.

TF_VAR_hcloud_token=""

TF_WORKSPACE="production"
TARGET_ENVIRONMENTS="production"

# Windows: use a full path like C:\Users\you\.ssh\id_ed25519 -- ~ does not expand reliably here
SSH_KEY_PATH="~/.ssh/id_ed25519"
# IP of this server -- set AFTER first `tofu apply`, from its output
SSH_HOST=""

S3_ACCESS_KEY=""
S3_SECRET_KEY=""

POSTGRES_DB_PASSWORD_PRODUCTION=""
