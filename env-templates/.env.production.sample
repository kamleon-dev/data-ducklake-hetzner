# Used for: `make duckdb` -- connects to the PRODUCTION environment.
# Lives on the dedicated production server (different SSH_HOST from dev/preprod).

# Windows: use a full path like C:\Users\you\.ssh\id_ed25519 -- ~ does not expand reliably here
SSH_KEY_PATH="~/.ssh/id_ed25519"
# IP of the dedicated production server
SSH_HOST=""

POSTGRES_DATABASE="ducklake_catalog_production"
POSTGRES_USER="ducklake_production"
# must match POSTGRES_DB_PASSWORD_PRODUCTION used at deploy time
POSTGRES_DB_PASSWORD=""

S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT="nbg1.your-objectstorage.com"
S3_REGION="nbg1"
S3_BUCKET_NAME="data-palantir-production"
S3_DATA_PATH="s3://data-palantir-production/"
S3_USE_SSL=true
